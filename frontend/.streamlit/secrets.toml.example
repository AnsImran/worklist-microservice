# Copy this file to secrets.toml and fill in real values.
# Generate a bcrypt hash with:
#   python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"

[auth]
username = "admin"
name = "Admin"
password_hash = "$2b$12$REPLACE_WITH_REAL_BCRYPT_HASH"
cookie_key = "replace-this-with-a-random-string"
